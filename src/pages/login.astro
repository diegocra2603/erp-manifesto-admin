 */
import { LoginPage } from '@/components/pages/auth/LoginPage';
import '@/styles/globals.css';
---

<!doctype html>
<html lang="es" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
