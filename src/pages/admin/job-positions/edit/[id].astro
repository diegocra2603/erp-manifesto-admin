---
/**
 * ============================================
 * EDIT JOB POSITION PAGE
 * ============================================
 */
import { JobPositionEditPage } from '@/components/pages/job-position/JobPositionEditPage';
import '@/styles/globals.css';

const { id } = Astro.params;
const jobPositionId = id ?? '';

if (!jobPositionId) {
  return Astro.redirect('/admin/job-positions');
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#ffffff" />
    <title>Editar Puesto de Trabajo - Restaurant Admin</title>
  </head>
  <body>
    <JobPositionEditPage client:only="react" jobPositionId={jobPositionId} currentPath="/admin/job-positions" />
  </body>
</html>
