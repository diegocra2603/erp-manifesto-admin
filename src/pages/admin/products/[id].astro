---
/**
 * ============================================
 * PRODUCT DETAIL PAGE
 * ============================================
 */
import { ProductDetailPageWrapper } from '@/components/pages/product/ProductDetailPageWrapper';
import '@/styles/globals.css';

const { id } = Astro.params;
const productId = id ?? '';

if (!productId) {
  return Astro.redirect('/admin/products');
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#ffffff" />
    <title>Detalle de Producto - Restaurant Admin</title>
  </head>
  <body>
    <ProductDetailPageWrapper client:only="react" productId={productId} currentPath="/admin/products" />
  </body>
</html>
